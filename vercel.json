{
  "rewrites": [
    { "source": "/__clerk/:path*", "destination": "https://frontend-api.clerk.dev/:path*" },
    { "source": "/app", "destination": "/app.html" }
  ],
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
